{
  "name": "mojo-dojo",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-agent orchestration core for Mojo-Dojo",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.96.0"
  },
  "activationEvents": [
    "onCommand:mojoDojo.runSecondOpinionAudit",
    "onCommand:mojoDojo.secondOpinion",
    "onCommand:mojoDojo.auditThis"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mojoDojo.runSecondOpinionAudit",
        "title": "Mojo-Dojo: Run Second Opinion Audit",
        "category": "Mojo-Dojo"
      },
      {
        "command": "mojoDojo.secondOpinion",
        "title": "Mojo-Dojo: Second Opinion",
        "category": "Mojo-Dojo"
      },
      {
        "command": "mojoDojo.auditThis",
        "title": "Mojo-Dojo: Audit This",
        "category": "Mojo-Dojo"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "fixtures:audit": "node dist/tools/runAuditFixtures.js",
    "fixtures:audit:local": "npm run build && npm run fixtures:audit",
    "vscode:prepublish": "npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.8.2"
  }
}
